# En Peyar - Local Environment Variables Example
# Copy this file to '.env' and fill in your keys.

# Groq API Key (Required)
# Get your key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Note:
# Earlier versions of En Peyar experimented with multiple AI providers
# (Gemini and OpenAI) as fallback agents for name generation. After
# testing and optimization, those integrations were removed to simplify
# the architecture and focus on a single provider.

# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=1
